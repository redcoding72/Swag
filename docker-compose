version: "3.8"
services:
  swag:
    image: lscr.io/linuxserver/swag:latest
    container_name: swag
    cap_add:
      - NET_ADMIN
    environment:
      - PUID=996
      - PGID=100
      - TZ=Africa/Algriers
      - URL=gb-service.duckdns.org
      - SUBDOMAINS=wildcard
      - VALIDATION=duckdns
      - EMAIL=redcoding72@gmail.com
    volumes:
      - /appdata/swag:/config
    ports:
      - 443:443
      - 80:80
    restart: unless-stopped
